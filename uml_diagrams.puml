@startuml LLM_Disco_Class_Diagram
title LLM Disco - Class Diagram

skinparam classAttributeIconSize 0

package "Models" {
  class ChatMessage {
    + role : String
    + content : String
    + timestamp : DateTime
    + images : List<String>?
    + thinking : String?
    + toolCalls : List?
    + files : List?
    --
    + toApiMap() : Map
    + toJson() : Map
  }

  class Conversation {
    + id : String
    + title : String
    + model : String
    + messages : List<ChatMessage>
    + thinkingEnabled : bool
    + webSearchEnabled : bool
    + numCtx : int?
    + filesEnabled : bool
    --
    + toJson() : Map
  }

  class ModelCapabilities {
    + supportsVision : bool
    + supportsThinking : bool
    + thinkingMode : String?
    + supportsTools : bool
    + supportsFiles : bool
  }

  Conversation "1" *-- "0..*" ChatMessage
}

package "Services" {
  class OllamaService {
    + baseUrl : String
    --
    + streamChat(model, messages) : Stream
    + fetchModels() : Future<List<String>>
    + fetchModelInfo(model) : Future<Map>
    + pullModel(name) : Stream
    + deleteModel(name) : Future<void>
    + searchSearXNG(url, query) : Future<List>
    + testConnection() : Future<bool>
    + cancelStream() : void
  }

  class StorageService {
    --
    + loadConversations() : Future<List>
    + saveConversations(list) : Future<void>
    + loadConnectionSettings() : Future<Map?>
    + saveConnectionSettings(...) : Future<void>
    + exportConversation(conv) : Future<File>
    + importConversations(path) : Future<List>
  }
}

package "Providers" {
  class ConnectionProvider {
    + service : OllamaService?
    + isConnected : bool
    + error : String?
    --
    + connect(ip, port, useHttp) : Future<bool>
    + disconnect() : void
  }

  class ChatProvider {
    + conversations : List<Conversation>
    + activeConversation : Conversation?
    + isStreaming : bool
    --
    + createConversation(model) : Conversation
    + sendMessage(content) : Future<void>
    + stopStreaming() : void
    + deleteConversation(id) : void
    + retryLastMessage() : Future<void>
  }

  class ModelProvider {
    + models : List<String>
    + selectedModel : String?
    --
    + fetchModels(service) : Future<void>
    + fetchCapabilities(service, model) : Future<void>
    + selectModel(model) : void
    + pullModel(service, name) : Future<void>
  }

  ConnectionProvider "1" --> "0..1" OllamaService : creates
  ChatProvider "1" --> "0..1" OllamaService : uses
  ChatProvider "1" --> "0..1" StorageService : saves via
  ChatProvider "1" --> "0..*" Conversation : manages
  ModelProvider "1" --> "0..1" OllamaService : uses
  ModelProvider "1" --> "0..*" ModelCapabilities : caches
}

package "Screens" {
  class ConnectionScreen
  class MainScreen
  class ModelManagementScreen

  ConnectionScreen ..> ConnectionProvider : reads/writes
  ConnectionScreen ..> ModelProvider : fetches models
  MainScreen ..> ChatProvider : reads/writes
  MainScreen ..> ModelProvider : reads capabilities
  ModelManagementScreen ..> ModelProvider : manages models
}

@enduml


@startuml LLM_Disco_Navigation
title LLM Disco - Screen Navigation

[*] --> ConnectionScreen : App Launch

ConnectionScreen --> MainScreen : Connect Success
MainScreen --> ConnectionScreen : Disconnect
MainScreen --> ModelManagementScreen : Manage Models
ModelManagementScreen --> MainScreen : Back

@enduml


@startuml LLM_Disco_SendMessage_Sequence
title LLM Disco - Send Message (with Tool-Calling)

actor User
participant MainScreen
participant ChatProvider
participant OllamaService
participant "Ollama Server" as Ollama
participant SearXNG

User -> MainScreen : type & tap Send
MainScreen -> ChatProvider : sendMessage(content)
ChatProvider -> ChatProvider : create user message\nadd to conversation

loop tool-calling loop (max 5 iterations)
  ChatProvider -> OllamaService : streamChat(model, messages, tools?)
  OllamaService -> Ollama : POST /api/chat

  loop streaming tokens
    Ollama --> OllamaService : JSON chunk
    OllamaService --> ChatProvider : ChatStreamEvent
    ChatProvider -> ChatProvider : append to\nassistant message
    ChatProvider --> MainScreen : notifyListeners()
  end

  Ollama --> OllamaService : done: true

  alt tool_calls received
    ChatProvider -> OllamaService : searchSearXNG(query)
    OllamaService -> SearXNG : GET /search?q=...
    SearXNG --> OllamaService : JSON results
    OllamaService --> ChatProvider : search results
    ChatProvider -> ChatProvider : add tool message\nwith results
    note right: loop continues\nwith tool results
  else no tool_calls
    note right: break loop
  end
end

ChatProvider -> ChatProvider : persist to storage

@enduml
